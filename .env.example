# bb-proxy config — copy to .env for local dev or set in Coolify UI for prod

# Required
ADMIN_PASSWORD=change-me-to-a-long-random-string
PUBLIC_BASE_URL=http://localhost:8080

# Listening
PORT=8080
HOST=0.0.0.0
# Optional second listener on plain HTTP for BB devices (they can't speak modern TLS).
# If BB_PLAIN_HTTP_PORT is set, the server binds a second port with no TLS hooks.
BB_PLAIN_HTTP_PORT=

# Spotify (create app at developer.spotify.com → dashboard → create app)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8080/admin/spotify/callback

# Storage
DATA_DIR=./data

# Logging
LOG_LEVEL=info

# Feature toggles (for dev — disable heavy modules you don't need running)
ENABLE_BROWSER=1
ENABLE_SPOTIFY=1
ENABLE_WHATSAPP=1
