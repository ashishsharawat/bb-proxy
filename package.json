{
  "name": "bb-proxy",
  "version": "0.1.0",
  "description": "Proxy server bridging BlackBerry Bold 9900 apps to modern web, Spotify, and WhatsApp.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/basic-auth": "^6.0.0",
    "@fastify/cookie": "^9.3.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fluent-ffmpeg": "^2.1.3",
    "jsdom": "^25.0.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "playwright": "^1.47.0",
    "sharp": "^0.33.5",
    "spotify-web-api-node": "^5.0.2",
    "ulid": "^2.3.0",
    "whatsapp-web.js": "^1.26.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.16.5",
    "@types/qrcode": "^1.5.5",
    "@types/spotify-web-api-node": "^5.0.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
